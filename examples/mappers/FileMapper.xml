<?xml version="1.0" encoding="UTF-8"?>
<mapper namespace="FileMapper">

    <sql id="fileColumns">
        id, project_id, original_filename, stored_filename, filepath, created_at
    </sql>

    <!-- Query all files for a project -->
    <select id="selectByProjectId">
        SELECT <include refid="fileColumns"/>
        FROM project_files
        WHERE project_id = #{project_id}
        ORDER BY created_at DESC
    </select>

    <!-- Query file by ID -->
    <select id="selectById">
        SELECT <include refid="fileColumns"/>
        FROM project_files
        WHERE id = #{id}
    </select>

    <!-- Insert file record -->
    <insert id="insert">
        INSERT INTO project_files (
            project_id, original_filename, stored_filename, filepath, created_at
        ) VALUES (
            #{project_id}, #{original_filename}, #{stored_filename}, #{filepath}, NOW()
        )
    </insert>

    <!-- Delete file record -->
    <delete id="delete">
        DELETE FROM project_files WHERE id = #{id}
    </delete>

    <!-- Delete all files for a project -->
    <delete id="deleteByProjectId">
        DELETE FROM project_files WHERE project_id = #{project_id}
    </delete>

    <!-- Batch delete files by ID list -->
    <delete id="batchDelete">
        DELETE FROM project_files
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- Batch query files by ID list -->
    <select id="selectByIds">
        SELECT <include refid="fileColumns"/>
        FROM project_files
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
